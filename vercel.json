{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 300,
      "excludeFiles": "{node_modules,.next,.git,.venv,.pytest_cache,tests,Helix11,.code-review-graph,.pnpm-store,.vercel}/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
