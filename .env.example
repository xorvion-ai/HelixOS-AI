# ============================================================
# HelixOS AI — environment variables (copy to .env and fill in)
# Every key is OPTIONAL: with none set, the backend runs in demo
# mode (in-memory simulation, no external calls). Add keys to
# switch on real Gemini / Chroma / Supabase capabilities.
# ============================================================

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Google Gemini (free tier) ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Chroma Cloud (RAG vector store, free tier) ---
# https://www.trychroma.com/  (Settings -> API Keys)
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# --- Supabase (Postgres + Auth + Realtime) ---
# https://supabase.com/  (Project Settings -> API). With these set, each signed-in
# user gets a durable Postgres-backed workspace; unset = in-memory demo mode.
# Run supabase/migrations/0001_init.sql once in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
# Pooled Postgres connection string — reserved for the LangGraph Postgres
# checkpointer (a later phase); unused today.
DATABASE_URL=

# --- Next.js frontend (public) ---
# Base URL the browser uses to reach the API. Local dev points at the
# FastAPI dev server; on Vercel leave empty so it uses same-origin /api.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
# Supabase public creds for the browser (login + session). Leave blank for the
# demo (no login gate). Use the SAME url + anon key as the backend above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
